{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "peptideos",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "peptideos"
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "BETA_GATE_ENABLED": "true"
  }
  // Secrets (set via `pnpm exec wrangler secret put <NAME>` or Cloudflare dashboard):
  // - ANTHROPIC_API_KEY: enables AI protocol assistant
  // - SUPABASE_SERVICE_ROLE_KEY: enables private beta invite redemption
  // - BETA_GATE_COOKIE_SECRET: optional dedicated beta access cookie signing secret
}
