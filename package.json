{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "compound:validate": "vitest run lib/reference-compounds.test.ts",
    "compound:fetch-sources": "node tools/compound-curation/source-fetcher.mjs",
    "compound:package-reviewed": "node tools/compound-curation/package-reviewed.mjs",
    "library:export-reviewed": "node tools/reference-library/export-reviewed.mjs",
    "library:import-reviewed": "node tools/reference-library/import-reviewed.mjs",
    "library:seed-reviewed-sql": "node tools/reference-library/seed-reviewed-sql.mjs",
    "library:validate-records": "node tools/reference-library/validate-records.mjs --input reference-library/compounds",
    "library:build-records": "node tools/reference-library/build-records.mjs --input reference-library/compounds --output app/generated/reference-library.snapshot.json",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ci": "playwright test",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "dependencies": {
