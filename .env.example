# AI Protocol Assistant (server-side only — never expose to the client)
# Get a key at https://platform.claude.com/
# Local dev: put it in .env.local
# Production (Cloudflare Workers): `pnpm exec wrangler secret put ANTHROPIC_API_KEY`
ANTHROPIC_API_KEY=

# Optional: override the model used for protocol parsing (defaults to claude-haiku-4-5).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional auth foundation (browser-safe Supabase public values)
# Local dev: put these in .env.local
# Production (Cloudflare Workers): configure as public build/runtime env vars.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Private beta gate. Keep disabled locally unless testing the gate.
NEXT_PUBLIC_BETA_GATE_ENABLED=false

# Server-side only: required for beta invite redemption.
# Production: `pnpm exec wrangler secret put SUPABASE_SERVICE_ROLE_KEY`
SUPABASE_SERVICE_ROLE_KEY=
