# AI Protocol Assistant (server-side only - never expose client)
# Get key at https://platform.claude.com/
# Local dev: put it in .env.local
# Production (Cloudflare Workers): `pnpm exec wrangler secret put ANTHROPIC_API_KEY`
ANTHROPIC_API_KEY=

# Optional: model used protocol parsing (defaults claude-haiku-4-5).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional auth foundation (browser-safe Supabase public values)
# Local dev: put these in .env.local
# Production (Cloudflare Workers): configure public build/runtime env vars.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Private beta gate. Server-side only; use false for local/e2e smoke tests.
BETA_GATE_ENABLED=false
BETA_GATE_COOKIE_SECRET=

# Server-side only: required beta invite redemption.
# Production: `pnpm exec wrangler secret put SUPABASE_SERVICE_ROLE_KEY`
SUPABASE_SERVICE_ROLE_KEY=
